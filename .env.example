# Required (only ANTHROPIC_API_KEY is needed — DATABASE_URL is set automatically by Docker Compose)
# DATABASE_URL=postgresql+asyncpg://scorched:scorched@localhost:5432/scorched  # Only needed for non-Docker runs
ANTHROPIC_API_KEY=sk-ant-...

# Portfolio configuration
STARTING_CAPITAL=100000

# Tax rates (optional — these are the defaults)
SHORT_TERM_TAX_RATE=0.37
LONG_TERM_TAX_RATE=0.20

# Optional data source API keys
ALPHA_VANTAGE_API_KEY=
# Twelvedata — free tier 800 calls/day; RSI for full watchlist (replaces Alpha Vantage's 25/day limit)
# https://twelvedata.com/account/api-keys
TWELVEDATA_API_KEY=
# POLYGON_API_KEY — removed April 2026; Alpaca news replaced Polygon entirely

# Server
HOST=0.0.0.0
PORT=8000

FRED_API_KEY=
FINNHUB_API_KEY=

# Broker integration (optional — defaults to paper-only, no broker needed)
# Options: "paper" (DB-only), "alpaca_paper" (Alpaca paper trading), "alpaca_live" (real money)
BROKER_MODE=paper
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Dashboard security (optional — if set, editing strategy requires this PIN)
SETTINGS_PIN=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
